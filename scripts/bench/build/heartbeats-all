#!/usr/bin/env bash
set -euo pipefail

source "$(dirname "$0")/../heartbeat-common.sh"

repo="$(bench_repo_root)"
heartbeat_check="$repo/scripts/bench/build/HeartbeatCheck.lean"
output="measurements.jsonl"
build_root=".lake/build/lib/lean"
jobs="${BENCH_HEARTBEAT_JOBS:-}"

if [ -z "$jobs" ]; then
  jobs="$(getconf _NPROCESSORS_ONLN 2>/dev/null || echo 1)"
  if [ "$jobs" -gt 6 ]; then
    jobs=6
  fi
fi

case "$jobs" in
  '' | *[!0-9]* | 0)
    echo "invalid BENCH_HEARTBEAT_JOBS: $jobs" >&2
    exit 1
    ;;
esac

tmpdir="$(mktemp -d)"
module_list="$tmpdir/modules"
trap 'rm -rf "$tmpdir"' EXIT

find "$build_root/Clean" -name '*.olean' -print \
  | sed -e "s|^$build_root/||" -e 's|\.olean$||' -e 's|/|.|g' \
  | sort > "$module_list"

measure_module() {
  local module="$1"
  local path
  local value
  local lines

  path="$(module_path "$module")"
  if [ ! -f "$path" ]; then
    return 0
  fi
  value="$(measure_heartbeats "$repo" "$module" "$heartbeat_check")"
  lines="$(wc -l < "$path")"
  python3 - "$tmpdir/$module.jsonl" "$module" "$value" "$lines" <<'PY'
import json
import sys

output, module, heartbeats, lines = sys.argv[1:]
records = [
    {"metric": f"build/module/{module}//heartbeats", "value": float(heartbeats), "unit": "heartbeats"},
    {"metric": f"build/module/{module}//lines", "value": float(lines)},
]
with open(output, "a", encoding="utf-8") as handle:
    for record in records:
        handle.write(json.dumps(record) + "\n")
PY
}

export repo heartbeat_check tmpdir
export -f bench_repo_root module_path measure_heartbeats measure_module

xargs -r -n 1 -P "$jobs" bash -c 'measure_module "$1"' bash < "$module_list"

while IFS= read -r module; do
  if [ -f "$tmpdir/$module.jsonl" ]; then
    cat "$tmpdir/$module.jsonl"
  fi
done < "$module_list" >> "$output"
